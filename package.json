{
  "name": "leasing-commission-system",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @lcs/web dev",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "prisma:validate": "pnpm --filter @lcs/database prisma:validate",
    "prisma:generate": "pnpm --filter @lcs/database prisma:generate"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}

